{
  "manifest_version": 3,
  "name": "Prompt Enhancer",
  "version": "1.0",
  "description": "Enhance any AI prompt with one click",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://*.chat.openai.com/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "https://gemini.google.com/*",
        "https://*.gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://*.copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://*.chat.mistral.ai/*",
        "https://perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://poe.com/*",
        "https://*.poe.com/*",
        "https://character.ai/*",
        "https://*.character.ai/*",
        "https://you.com/*",
        "https://*.you.com/*",
        "https://phind.com/*",
        "https://*.phind.com/*",
        "https://bolt.new/*",
        "https://*.bolt.new/*",
        "https://v0.dev/*",
        "https://*.v0.dev/*",
        "https://cursor.com/*",
        "https://*.cursor.com/*",
        "https://replit.com/*",
        "https://*.replit.com/*",
        "https://colab.research.google.com/*",
        "https://huggingface.co/*",
        "https://*.huggingface.co/*",
        "https://playground.ai/*",
        "https://*.playground.ai/*",
        "https://ideogram.ai/*",
        "https://*.ideogram.ai/*",
        "https://midjourney.com/*",
        "https://*.midjourney.com/*",
        "https://leonardo.ai/*",
        "https://*.leonardo.ai/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Prompt Enhancer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
